; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="蚂蚁化工 AntChem"
config/description="Army ant explosive engineer — chemistry synthesis + physics demolition."
config/version="0.1.0-prototype"
run/main_scene="res://scenes/cave_lab.tscn"
config/features=PackedStringArray("4.4")
config/icon="res://assets/icon.svg"

[autoload]

RecipeDB="*res://autoload/recipe_db.gd"
EquipmentStore="*res://autoload/equipment_store.gd"
InventoryManager="*res://autoload/inventory_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
quality/2d/use_pixel_snap=true
